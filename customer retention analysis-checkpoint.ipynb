    "# ==========================================\n",
    "# PROJECT 2: CUSTOMER RETENTION ANALYSIS\n",
    "# ==========================================\n",
    "\n",
    "# Import Libraries\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# ------------------------------------------\n",
    "# Step 1: Load Dataset\n",
    "# ------------------------------------------\n",
    "df = pd.read_csv('C:\\Users\\kousthubha\\Downloads\\customer.csv')\n",
    "\n",
    "# Convert date column\n",
    "df['InvoiceDate'] = pd.to_datetime(df['InvoiceDate'])\n",
    "\n",
    "# Create Total Amount\n",
    "df['TotalAmount'] = df['Quantity'] * df['UnitPrice']\n",
    "\n",
    "print(\"Dataset Preview:\")\n",
    "print(df.head())\n",
    "\n",
    "# ------------------------------------------\n",
    "# Step 2: RFM ANALYSIS\n",
    "# ------------------------------------------\n",
    "\n",
    "# Reference date\n",
    "reference_date = df['InvoiceDate'].max() + pd.Timedelta(days=1)\n",
    "\n",
    "# GroupBy (important as per image)\n",
    "rfm = df.groupby('CustomerID').agg({\n",
    "    'InvoiceDate': lambda x: (reference_date - x.max()).days,\n",
    "    'InvoiceNo': 'count',\n",
    "    'TotalAmount': 'sum'\n",
    "})\n",
    "\n",
    "rfm.columns = ['Recency', 'Frequency', 'Monetary']\n",
    "rfm.reset_index(inplace=True)\n",
    "\n",
    "print(\"\\nRFM Table:\")\n",
    "print(rfm.head())\n",
    "\n",
    "# ------------------------------------------\n",
    "# Step 3: RFM SCORING\n",
    "# ------------------------------------------\n",
    "rfm['R_Score'] = pd.qcut(rfm['Recency'], 4, labels=[4,3,2,1])\n",
    "rfm['F_Score'] = pd.qcut(rfm['Frequency'].rank(method='first'), 4, labels=[1,2,3,4])\n",
    "rfm['M_Score'] = pd.qcut(rfm['Monetary'], 4, labels=[1,2,3,4])\n",
    "\n",
    "rfm['RFM_Score'] = rfm['R_Score'].astype(str) + \\\n",
    "                   rfm['F_Score'].astype(str) + \\\n",
    "                   rfm['M_Score'].astype(str)\n",
    "\n",
    "# ------------------------------------------\n",
    "# Step 4: CUSTOMER SEGMENTATION\n",
    "# ------------------------------------------\n",
    "def segment(row):\n",
    "    if row['RFM_Score'] == '444':\n",
    "        return 'Best Customers'\n",
    "    elif int(row['R_Score']) >= 3 and int(row['F_Score']) >= 3:\n",
    "        return 'Loyal Customers'\n",
    "    elif int(row['R_Score']) <= 2:\n",
    "        return 'At Risk'\n",
    "    else:\n",
    "        return 'Others'\n",
    "\n",
    "rfm['Segment'] = rfm.apply(segment, axis=1)\n",
    "\n",
    "print(\"\\nSegments:\")\n",
    "print(rfm['Segment'].value_counts())\n",
    "\n",
    "# ------------------------------------------\n",
    "# Step 5: CHURN DETECTION\n",
    "# ------------------------------------------\n",
    "rfm['Churn'] = np.where(rfm['Recency'] > 60, 'Churned', 'Active')\n",
    "\n",
    "print(\"\\nChurn Summary:\")\n",
    "print(rfm['Churn'].value_counts())\n",
    "\n",
    "# ------------------------------------------\n",
    "# Step 6: COHORT ANALYSIS\n",
    "# ------------------------------------------\n",
    "\n",
    "# Extract month\n",
    "df['Month'] = df['InvoiceDate'].dt.to_period('M')\n",
    "\n",
    "cohort = df.groupby(['Month', 'CustomerID']).size().reset_index(name='Transactions')\n",
    "\n",
    "print(\"\\nCohort Data:\")\n",
    "print(cohort.head())\n",
    "\n",
    "# ------------------------------------------\n",
    "# Step 7: CORRELATION ANALYSIS\n",
    "# ------------------------------------------\n",
    "correlation = rfm[['Recency','Frequency','Monetary']].corr()\n",
    "\n",
    "print(\"\\nCorrelation Matrix:\")\n",
    "print(correlation)\n",
    "\n",
    "# ------------------------------------------\n",
    "# Step 8: VISUALIZATIONS\n",
    "# ------------------------------------------\n",
    "\n",
    "# Segmentation\n",
    "plt.figure(figsize=(8,5))\n",
    "sns.countplot(x='Segment', data=rfm)\n",
    "plt.title(\"Customer Segmentation\")\n",
    "plt.xticks(rotation=30)\n",
    "plt.show()\n",
    "\n",
    "# Churn\n",
    "plt.figure(figsize=(6,4))\n",
    "sns.countplot(x='Churn', data=rfm)\n",
    "plt.title(\"Churn vs Active Customers\")\n",
    "plt.show()\n",
    "\n",
    "# Correlation Heatmap\n",
    "plt.figure(figsize=(6,4))\n",
    "sns.heatmap(correlation, annot=True)\n",
    "plt.title(\"RFM Correlation\")\n",
    "plt.show()\n",
    "\n",
    "# ------------------------------------------\n",
    "# Step 9: SAVE OUTPUT\n",
    "# ------------------------------------------\n",
    "rfm.to_csv(\"rfm_output.csv\", index=False)\n",
    "\n",
    "print(\"\\n✅ Project Completed - Output Saved as rfm_output.csv\")"
   ]
  },
